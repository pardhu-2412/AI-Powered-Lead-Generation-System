<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Lead_Score</fullName>
    <active>true</active>
    <errorConditionFormula>OR(
 Lead_Score_c__c &lt; 0,
 Lead_Score_c__c &gt; 100
)</errorConditionFormula>
    <errorDisplayField>Lead_Score_c__c</errorDisplayField>
    <errorMessage>Lead Score must be between 0 and 100.</errorMessage>
</ValidationRule>
