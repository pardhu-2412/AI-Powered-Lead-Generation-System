<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Product_Interest_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
ISPICKVAL(Lead_Category__c, &quot;Hot&quot;),
ISBLANK(TEXT(Product_Interest__c))
)</errorConditionFormula>
    <errorDisplayField>Product_Interest__c</errorDisplayField>
    <errorMessage>Select Product Interest for Hot Leads.</errorMessage>
</ValidationRule>
